{
  "version": 2,
  "installCommand": "cd frontend && npm install --include=dev",
  "buildCommand": "cd frontend && npm run build",
  "build": {
    "env": {
      "NPM_CONFIG_PRODUCTION": "false"
    }
  },
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ]
}
